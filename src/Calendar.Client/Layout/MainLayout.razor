@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager NavigationManager
@inject global::Calendar.Client.Services.AuthService AuthService
@inject global::Calendar.Client.Services.AppointmentService AppointmentService
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<MudThemeProvider @ref="@_themeProvider" @bind-IsDarkMode="@_isDarkMode" Theme="OrganicTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h6" Class="ml-3" Style="font-weight: 600; color: var(--primary);">Calendar App</MudText>
        <MudSpacer />
        
        <AuthorizeView>
            <Authorized>
                <MudButton Color="Color.Inherit" OnClick="Logout" StartIcon="@Icons.Material.Filled.Logout">Đăng xuất</MudButton>
            </Authorized>
            <NotAuthorized>
                <MudButton Color="Color.Inherit" Href="/login">Đăng nhập</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Elevation="0" ClipMode="DrawerClipMode.Always">
        <NavMenu />
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = false;
    private MudThemeProvider _themeProvider;
    private CancellationTokenSource? _reminderCts;

    protected override void OnInitialized()
    {
        _reminderCts = new CancellationTokenSource();
        _ = StartReminderPollingAsync(_reminderCts.Token);
    }

    private async Task StartReminderPollingAsync(CancellationToken ct)
    {
        try
        {
            await Task.Delay(5000, ct);
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(30));
            while (await timer.WaitForNextTickAsync(ct))
            {
                await InvokeAsync(CheckReminders);
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task CheckReminders()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!(authState.User.Identity?.IsAuthenticated ?? false)) return;

        var result = await AppointmentService.GetDueRemindersAsync();
        if (result.Success && result.Data?.Any() == true)
        {
            foreach (var reminder in result.Data)
            {
                Snackbar.Add($"[NHẮC LỊCH] {reminder.AppointmentName} lúc {reminder.StartTime.ToLocalTime():HH:mm}", 
                    Severity.Info, config => {
                        config.Icon = Icons.Material.Filled.Alarm;
                    });
            }
        }
    }

    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
    }
    
    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/login");
    }

    public void Dispose()
    {
        _reminderCts?.Cancel();
        _reminderCts?.Dispose();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Removed GetSystemPreference to avoid MudBlazor compatibility errors
