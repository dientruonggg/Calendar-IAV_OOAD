
<div style="border: 1px solid var(--outline-variant, #c4c8bb); background: var(--surface-container-lowest, #ffffff); border-radius: 12px; overflow: hidden; font-family: 'Inter', sans-serif;">
    <div style="display: grid; grid-template-columns: repeat(7, 1fr); background: var(--surface-container-low, #faf3e7); border-bottom: 2px solid var(--outline-variant, #c4c8bb);">
        @foreach (var day in new[] { "Hai", "Ba", "Tư", "Năm", "Sáu", "Bảy", "CN" })
        {
            <div style="padding: 10px; text-align: center; font-weight: 600; font-size: 13px; color: var(--on-surface-variant, #44483f);">@day</div>
        }
    </div>

    <div style="display: grid; grid-template-columns: repeat(7, 1fr); grid-auto-rows: minmax(120px, auto);">
        @for (int i = 0; i < DaysInView.Count; i++)
        {
            var day = DaysInView[i];
            var isCurrentMonth = day.Month == CurrentDate.Month;
            var isToday = day.Date == DateTime.Today;

            <div style="border: 0.5px solid var(--surface-container-high, #eee7dc); padding: 4px;
                        background: @(isCurrentMonth ? "var(--surface-container-lowest, #ffffff)" : "var(--surface-container-low, #faf3e7)");
                        @(isToday ? "outline: 2px solid var(--primary, #3d532b); z-index: 1;" : "")
                        cursor: pointer; transition: background 0.15s;"
                 @onclick="() => OnSlotClick.InvokeAsync(day.AddHours(9))">
                <div style="text-align: right; margin-bottom: 4px; font-weight: @(isToday ? "700" : "500"); font-size: 13px;
                            color: @(isToday ? "var(--primary, #3d532b)" : (isCurrentMonth ? "var(--on-surface, #1e1b14)" : "var(--outline, #74796e)"))">
                    @if (isToday)
                    {
                        <span style="background: var(--primary-container, #546b41); color: var(--on-primary-container, #d0ebb6); padding: 2px 6px; border-radius: 9999px;">@day.Day</span>
                    }
                    else
                    {
                        @day.Day
                    }
                </div>
                <div style="display: flex; flex-direction: column; gap: 2px;">
                    @* All-day events first *@
                    @foreach (var appt in Appointments.Where(a => a.IsAllDay && a.StartTime.Date <= day.Date && a.EndTime.Date >= day.Date))
                    {
                        @if (appt.IsGroupMeeting)
                        {
                            <div @onclick:stopPropagation="true" @onclick="() => OnEventClick.InvokeAsync(appt.Id)"
                                 style="background: linear-gradient(135deg, #7C3AED, #5B21B6);
                                        color: white; padding: 2px 6px; border-radius: 4px; font-size: 10px;
                                        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
                                        cursor: pointer; border: 1px dashed rgba(255,255,255,0.4);
                                        display: flex; align-items: center; gap: 3px; font-weight: 600;">
                                <span>👥</span>
                                <span style="overflow: hidden; text-overflow: ellipsis;">@appt.Name</span>
                            </div>
                        }
                        else
                        {
                            <div @onclick:stopPropagation="true" @onclick="() => OnEventClick.InvokeAsync(appt.Id)"
                                 style="background: var(--primary-fixed, #d0ebb7); color: var(--on-primary-fixed, #0d2001); padding: 2px 6px;
                                        border-radius: 4px; font-size: 10px; white-space: nowrap;
                                        overflow: hidden; text-overflow: ellipsis; cursor: pointer;
                                        font-weight: 600; border-left: 3px solid var(--primary, #3d532b);">
                                🕐 @appt.Name
                            </div>
                        }
                    }

                    @* Timed events *@
                    @foreach (var appt in Appointments.Where(a => !a.IsAllDay && a.StartTime.Date == day.Date))
                    {
                        @if (appt.IsGroupMeeting)
                        {
                            <div @onclick:stopPropagation="true" @onclick="() => OnEventClick.InvokeAsync(appt.Id)"
                                 style="background: linear-gradient(135deg, #7C3AED, #5B21B6);
                                        color: white; padding: 2px 6px; border-radius: 4px; font-size: 10px;
                                        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
                                        cursor: pointer; border: 1px dashed rgba(255,255,255,0.4);
                                        display: flex; align-items: center; gap: 3px;">
                                <span>👥</span>
                                <span style="overflow: hidden; text-overflow: ellipsis;">
                                    @appt.StartTime.ToString("HH:mm") @appt.Name
                                </span>
                                @if (appt.IsCurrentUserParticipant)
                                {
                                    <span style="margin-left: auto; font-size: 9px; opacity: 0.9;">✓</span>
                                }
                            </div>
                        }
                        else
                        {
                            <div @onclick:stopPropagation="true" @onclick="() => OnEventClick.InvokeAsync(appt.Id)"
                                 style="background: var(--primary-fixed, #d0ebb7); color: var(--on-primary-fixed, #0d2001); padding: 2px 6px;
                                        border-radius: 4px; font-size: 11px; white-space: nowrap;
                                        overflow: hidden; text-overflow: ellipsis; cursor: pointer;
                                        border-left: 3px solid @(appt.Color ?? "var(--primary, #3d532b)");">
                                @appt.StartTime.ToString("HH:mm") @appt.Name
                            </div>
                        }
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public DateTime CurrentDate { get; set; }
    [Parameter] public List<AppointmentListResponse> Appointments { get; set; } = new();
    [Parameter] public EventCallback<DateTime> OnSlotClick { get; set; }
    [Parameter] public EventCallback<Guid> OnEventClick { get; set; }

    private List<DateTime> DaysInView
    {
        get
        {
            var startOfMonth = new DateTime(CurrentDate.Year, CurrentDate.Month, 1);
            var start = startOfMonth.AddDays(-1 * ((7 + (startOfMonth.DayOfWeek - DayOfWeek.Monday)) % 7));
            var end = start.AddDays(42);

            var list = new List<DateTime>();
            for (var d = start; d < end; d = d.AddDays(1))
                list.Add(d);
            return list;
        }
    }
}
