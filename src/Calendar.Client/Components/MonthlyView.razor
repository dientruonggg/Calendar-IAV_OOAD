@using Calendar.Shared.DTOs.Appointments

<div class="monthly-view" style="border: 1px solid #ddd; background: white;">
    <div style="display: grid; grid-template-columns: repeat(7, 1fr); background: #f5f5f5; border-bottom: 2px solid #ddd;">
        @foreach (var day in new[] { "Hai", "Ba", "Tư", "Năm", "Sáu", "Bảy", "CN" })
        {
            <div style="padding: 10px; text-align: center; font-weight: bold; font-size: 14px;">@day</div>
        }
    </div>

    <div style="display: grid; grid-template-columns: repeat(7, 1fr); grid-auto-rows: minmax(120px, auto);">
        @for (int i = 0; i < DaysInView.Count; i++)
        {
            var day = DaysInView[i];
            var isCurrentMonth = day.Month == CurrentDate.Month;
            var isToday = day.Date == DateTime.Today;

            <div style="border: 0.5px solid #eee; padding: 4px; background: @(isCurrentMonth ? "white" : "#f9f9f9"); @(isToday ? "outline: 2px solid #1976d2; z-index: 1;" : "")"
                 @onclick="() => OnSlotClick.InvokeAsync(day.AddHours(9))">
                <div style="text-align: right; margin-bottom: 4px; font-weight: @(isToday ? "bold" : "normal"); color: @(isCurrentMonth ? "#333" : "#bbb")">
                    @day.Day
                </div>
                <div style="display: flex; flex-direction: column; gap: 2px;">
                    @foreach (var appt in Appointments.Where(a => a.StartTime.Date == day.Date))
                    {
                        @if (appt.IsGroupMeeting)
                        {
                            <div @onclick:stopPropagation="true" @onclick="() => OnEventClick.InvokeAsync(appt.Id)"
                                 style="background: linear-gradient(135deg, #7C3AED, #5B21B6);
                                        color: white; padding: 2px 6px; border-radius: 4px; font-size: 10px;
                                        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
                                        cursor: pointer; border: 1px dashed rgba(255,255,255,0.4);
                                        display: flex; align-items: center; gap: 3px;">
                                <span>👥</span>
                                <span style="overflow: hidden; text-overflow: ellipsis;">
                                    @appt.StartTime.ToString("HH:mm") @appt.Name
                                </span>
                                @if (appt.IsCurrentUserParticipant)
                                {
                                    <span style="margin-left: auto; font-size: 9px; opacity: 0.9;">✓</span>
                                }
                            </div>
                        }
                        else
                        {
                            <div @onclick:stopPropagation="true" @onclick="() => OnEventClick.InvokeAsync(appt.Id)"
                                 style="background: @(appt.Color ?? "#1976d2"); color: white; padding: 2px 6px;
                                        border-radius: 3px; font-size: 11px; white-space: nowrap;
                                        overflow: hidden; text-overflow: ellipsis; cursor: pointer;">
                                @appt.StartTime.ToString("HH:mm") @appt.Name
                            </div>
                        }
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public DateTime CurrentDate { get; set; }
    [Parameter] public List<AppointmentListResponse> Appointments { get; set; } = new();
    [Parameter] public EventCallback<DateTime> OnSlotClick { get; set; }
    [Parameter] public EventCallback<Guid> OnEventClick { get; set; }

    private List<DateTime> DaysInView
    {
        get
        {
            var startOfMonth = new DateTime(CurrentDate.Year, CurrentDate.Month, 1);
            var start = startOfMonth.AddDays(-1 * ((7 + (startOfMonth.DayOfWeek - DayOfWeek.Monday)) % 7));
            var end = start.AddDays(42);

            var list = new List<DateTime>();
            for (var d = start; d < end; d = d.AddDays(1))
                list.Add(d);
            return list;
        }
    }
}
