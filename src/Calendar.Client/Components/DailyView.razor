
<style>
    .daily-grid {
        display: grid;
        grid-template-columns: 72px 1fr;
        border: 1px solid var(--outline-variant, #c4c8bb);
        background: var(--surface-container-lowest, #ffffff);
        border-radius: 12px;
        overflow: hidden;
        box-sizing: border-box;
        font-family: 'Inter', sans-serif;
    }
    .daily-grid * {
        box-sizing: border-box;
    }
    .time-slot {
        height: 60px;
        border-bottom: 1px solid var(--surface-container-high, #eee7dc);
        text-align: center;
        font-size: 12px;
        color: var(--outline, #74796e);
        padding-top: 4px;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        font-weight: 500;
    }
    .day-column-content {
        height: 1440px;
        position: relative;
        cursor: pointer;
        background-image: linear-gradient(var(--surface-container-high, #eee7dc) 1px, transparent 1px);
        background-size: 100% 60px;
    }
    .daily-all-day-label {
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        color: var(--outline, #74796e);
        border-bottom: 2px solid var(--outline-variant, #c4c8bb);
        border-right: 1px solid var(--outline-variant, #c4c8bb);
        background: var(--surface-container-low, #faf3e7);
        padding: 6px 2px;
        font-weight: 500;
    }
    .daily-all-day-cell {
        min-height: 48px;
        border-bottom: 2px solid var(--outline-variant, #c4c8bb);
        padding: 4px 8px;
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        align-items: center;
    }
    .daily-all-day-event {
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 600;
        color: white;
        white-space: nowrap;
        cursor: pointer;
        box-shadow: 0 1px 4px rgba(84,107,65,0.12);
        transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    .daily-all-day-event:hover {
        transform: translateY(-1px);
        box-shadow: 0 3px 8px rgba(84,107,65,0.2);
    }
    .event-card {
        border-radius: 8px;
        overflow: hidden;
        cursor: pointer;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    .event-card:hover {
        transform: translateY(-1px) scale(1.005);
    }
</style>

<div class="daily-grid">
    @* ===== Header ===== *@
    <div style="border-right: 1px solid var(--outline-variant, #c4c8bb); background: var(--surface-container-low, #faf3e7);">
        <div style="height: 64px; border-bottom: 1px solid var(--outline-variant, #c4c8bb);"></div>
    </div>
    <div style="height: 64px; border-bottom: 1px solid var(--outline-variant, #c4c8bb); text-align: center; font-weight: 600; padding-top: 18px; background: var(--surface-container-low, #faf3e7); color: var(--on-surface, #1e1b14);">
        @CurrentDate.ToString("dddd, dd/MM/yyyy")
    </div>

    @* ===== All-Day Row ===== *@
    @{
        var allDayAppts = Appointments.Where(a => a.IsAllDay && a.StartTime.Date <= CurrentDate.Date && a.EndTime.Date >= CurrentDate.Date).ToList();
    }
    <div class="daily-all-day-label">
        Cả ngày
    </div>
    <div class="daily-all-day-cell">
        @foreach (var appt in allDayAppts)
        {
            @if (appt.IsGroupMeeting)
            {
                <div class="daily-all-day-event" @onclick="() => OnEventClick.InvokeAsync(appt.Id)"
                     style="background: linear-gradient(135deg, #7C3AED, #5B21B6); border: 1px dashed rgba(255,255,255,0.4);">
                    👥 @appt.Name
                </div>
            }
            else
            {
                <div class="daily-all-day-event" @onclick="() => OnEventClick.InvokeAsync(appt.Id)"
                     style="background-color: @(appt.Color ?? "#3d532b");">
                    @appt.Name
                </div>
            }
        }
        @if (!allDayAppts.Any())
        {
            <span style="font-size: 11px; color: var(--outline, #74796e); font-style: italic;">Không có sự kiện cả ngày</span>
        }
    </div>

    @* ===== Time Column ===== *@
    <div style="border-right: 1px solid var(--outline-variant, #c4c8bb); background: var(--surface-container-low, #faf3e7);">
        @for (int i = 0; i < 24; i++)
        {
            <div class="time-slot">
                @($"{i:D2}:00")
            </div>
        }
    </div>

    @* ===== Day Content ===== *@
    <div style="position: relative;">
        <div @onclick="() => OnSlotClick.InvokeAsync(CurrentDate.AddHours(9))" class="day-column-content">
            @foreach (var appt in Appointments.Where(a => a.StartTime.Date == CurrentDate.Date && !a.IsAllDay))
            {
                var top = appt.StartTime.Hour * 60 + appt.StartTime.Minute;
                var height = (appt.EndTime - appt.StartTime).TotalMinutes;
                if (height < 20) height = 20;

                @if (appt.IsGroupMeeting)
                {
                    <div class="event-card" @onclick:stopPropagation="true" @onclick="() => OnEventClick.InvokeAsync(appt.Id)"
                         style="position: absolute; top: @(top)px; height: @(height)px; left: 8px; right: 8px;
                                background: linear-gradient(135deg, #7C3AED, #5B21B6);
                                color: white; padding: 10px 14px; font-size: 14px;
                                box-shadow: 0 4px 12px rgba(124,58,237,0.4);
                                border: 2px dashed rgba(255,255,255,0.5); z-index: 10;">
                        <div style="display: flex; align-items: center; gap: 6px; font-weight: bold; margin-bottom: 4px;">
                            <span style="font-size: 16px;">👥</span> @appt.Name
                        </div>
                        <div style="font-size: 12px; opacity: 0.9;">
                            <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" Class="mr-1" Style="vertical-align: middle;" />
                            @appt.StartTime.ToString("HH:mm") - @appt.EndTime.ToString("HH:mm")
                        </div>
                        <div style="font-size: 11px; opacity: 0.8; margin-top: 2px;">
                            <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" Style="vertical-align: middle;" />
                            @appt.ParticipantCount người tham gia
                            @if (appt.IsCurrentUserParticipant)
                            {
                                <span style="margin-left: 4px; background: rgba(255,255,255,0.25); padding: 1px 6px; border-radius: 10px; font-size: 10px;">✓ Đã tham gia</span>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="event-card" @onclick:stopPropagation="true" @onclick="() => OnEventClick.InvokeAsync(appt.Id)"
                         style="position: absolute; top: @(top)px; height: @(height)px; left: 8px; right: 8px;
                                background-color: @(appt.Color ?? "#d0ebb7");
                                color: @(appt.Color != null ? "white" : "#0d2001");
                                padding: 10px; font-size: 14px;
                                box-shadow: 0 3px 8px rgba(84,107,65,0.15);
                                border-left: 5px solid @(appt.Color ?? "#3d532b"); z-index: 5;">
                        <div style="font-weight: 600; margin-bottom: 2px;">@appt.Name</div>
                        <div style="font-size: 12px; opacity: 0.8;">
                            <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" Class="mr-1" Style="vertical-align: middle;" />
                            @appt.StartTime.ToString("HH:mm") - @appt.EndTime.ToString("HH:mm")
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public DateTime CurrentDate { get; set; }
    [Parameter] public List<AppointmentListResponse> Appointments { get; set; } = new();
    [Parameter] public EventCallback<DateTime> OnSlotClick { get; set; }
    [Parameter] public EventCallback<Guid> OnEventClick { get; set; }
}
