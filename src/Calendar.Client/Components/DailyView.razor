@using Calendar.Shared.DTOs.Appointments

<style>
    .daily-grid {
        display: grid;
        grid-template-columns: 60px 1fr;
        border: 1px solid #ddd;
        background: white;
        box-sizing: border-box;
    }
    .daily-grid * {
        box-sizing: border-box;
    }
    .time-slot {
        height: 60px;
        border-bottom: 1px solid #eee;
        text-align: center;
        font-size: 12px;
        color: #888;
        padding-top: 4px;
        display: flex;
        justify-content: center;
        align-items: flex-start;
    }
    .day-column-content {
        height: 1440px; /* 24 * 60px */
        position: relative;
        cursor: pointer;
        background-image: linear-gradient(#eee 1px, transparent 1px);
        background-size: 100% 60px;
    }
</style>

<div class="daily-grid">
    <div class="time-column" style="border-right: 1px solid #ddd; background: #fafafa;">
        <div style="height: 40px; border-bottom: 1px solid #ddd;"></div>
        @for (int i = 0; i < 24; i++)
        {
            <div class="time-slot">
                @($"{i}:00")
            </div>
        }
    </div>

    <div class="day-column" style="position: relative;">
        <div style="height: 40px; border-bottom: 1px solid #ddd; text-align: center; font-weight: bold; padding-top: 8px; background: #f5f5f5;">
            @CurrentDate.ToString("dddd, dd/MM/yyyy")
        </div>

        <div @onclick="() => OnSlotClick.InvokeAsync(CurrentDate.AddHours(9))" class="day-column-content">
            @foreach (var appt in Appointments.Where(a => a.StartTime.Date == CurrentDate.Date && !a.IsAllDay))
            {
                var top = appt.StartTime.Hour * 60 + appt.StartTime.Minute;
                var height = (appt.EndTime - appt.StartTime).TotalMinutes;
                if (height < 20) height = 20;

                @if (appt.IsGroupMeeting)
                {
                    <div @onclick:stopPropagation="true" @onclick="() => OnEventClick.InvokeAsync(appt.Id)"
                         style="position: absolute; top: @(top)px; height: @(height)px; left: 8px; right: 8px;
                                background: linear-gradient(135deg, #7C3AED, #5B21B6);
                                color: white; border-radius: 8px; padding: 10px 14px; font-size: 14px;
                                overflow: hidden; cursor: pointer;
                                box-shadow: 0 4px 12px rgba(124,58,237,0.4);
                                border: 2px dashed rgba(255,255,255,0.5); z-index: 10;">
                        <div style="display: flex; align-items: center; gap: 6px; font-weight: bold; margin-bottom: 4px;">
                            <span style="margin-right: 6px; font-size: 16px;">👥</span> @appt.Name
                        </div>
                        <div style="font-size: 12px; opacity: 0.9;">
                            <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" Class="mr-1" Style="vertical-align: middle;" />
                            @appt.StartTime.ToString("HH:mm") - @appt.EndTime.ToString("HH:mm")
                        </div>
                        <div style="font-size: 11px; opacity: 0.8; margin-top: 2px;">
                            <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" Style="vertical-align: middle;" />
                            @appt.ParticipantCount người tham gia
                            @if (appt.IsCurrentUserParticipant)
                            {
                                <span style="margin-left: 4px; background: rgba(255,255,255,0.25); padding: 1px 6px; border-radius: 10px; font-size: 10px;">✓ Đã tham gia</span>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div @onclick:stopPropagation="true" @onclick="() => OnEventClick.InvokeAsync(appt.Id)"
                         style="position: absolute; top: @(top)px; height: @(height)px; left: 8px; right: 8px;
                                background-color: @(appt.Color ?? "#1976d2"); color: white; border-radius: 6px;
                                padding: 10px; font-size: 14px; overflow: hidden; cursor: pointer;
                                box-shadow: 0 3px 6px rgba(0,0,0,0.15); border-left: 5px solid rgba(0,0,0,0.2); z-index: 5;">
                        <div style="font-weight: bold; margin-bottom: 2px;">@appt.Name</div>
                        <div style="font-size: 12px; opacity: 0.9;">
                            <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" Class="mr-1" Style="vertical-align: middle;" />
                            @appt.StartTime.ToString("HH:mm") - @appt.EndTime.ToString("HH:mm")
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public DateTime CurrentDate { get; set; }
    [Parameter] public List<AppointmentListResponse> Appointments { get; set; } = new();
    [Parameter] public EventCallback<DateTime> OnSlotClick { get; set; }
    [Parameter] public EventCallback<Guid> OnEventClick { get; set; }
}
