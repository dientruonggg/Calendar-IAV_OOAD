
<style>
    .calendar-grid {
        display: grid;
        grid-template-columns: 72px repeat(7, 1fr);
        border: 1px solid var(--outline-variant, #c4c8bb);
        background: var(--surface-container-lowest, #ffffff);
        border-radius: 12px;
        overflow: hidden;
        box-sizing: border-box;
        font-family: 'Inter', sans-serif;
    }
    .calendar-grid * {
        box-sizing: border-box;
    }
    .time-slot {
        height: 60px;
        border-bottom: 1px solid var(--surface-container-high, #eee7dc);
        text-align: center;
        font-size: 11px;
        color: var(--outline, #74796e);
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding-top: 4px;
        font-weight: 500;
    }
    .day-column-content {
        height: 1440px; /* 24 * 60px */
        position: relative;
        cursor: pointer;
        background-image: linear-gradient(var(--surface-container-high, #eee7dc) 1px, transparent 1px);
        background-size: 100% 60px;
    }
    .all-day-label {
        height: auto;
        min-height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        color: var(--on-surface-variant, #44483f);
        border-bottom: 2px solid var(--outline-variant, #c4c8bb);
        border-right: 1px solid var(--outline-variant, #c4c8bb);
        background: var(--surface-container-low, #faf3e7);
        padding: 6px 4px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.02em;
    }
    .all-day-cell {
        min-height: 48px;
        border-bottom: 2px solid var(--outline-variant, #c4c8bb);
        border-right: 1px solid var(--surface-container-high, #eee7dc);
        padding: 4px;
        display: flex;
        flex-direction: column;
        gap: 3px;
        background: var(--surface-container-lowest, #ffffff);
    }
    .all-day-event {
        padding: 3px 6px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        color: white;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        cursor: pointer;
        box-shadow: 0 1px 3px rgba(84, 107, 65, 0.12);
        transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    .all-day-event:hover {
        transform: translateY(-1px);
        box-shadow: 0 3px 8px rgba(84, 107, 65, 0.2);
    }
    .event-card {
        border-radius: 6px;
        overflow: hidden;
        cursor: pointer;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
        line-height: 1.2;
    }
    .event-card:hover {
        transform: translateY(-1px) scale(1.01);
    }
</style>

<div class="calendar-grid">
    @* ===== Header Row ===== *@
    <div style="border-right: 1px solid var(--outline-variant, #c4c8bb); background: var(--surface-container-low, #faf3e7);">
        <div style="height: 64px; border-bottom: 1px solid var(--outline-variant, #c4c8bb);"></div>
    </div>

    @for (int d = 0; d < 7; d++)
    {
        var dayDate = StartOfWeek.AddDays(d);
        var isToday = dayDate.Date == DateTime.Today;

        <div style="height: 64px; border-bottom: 1px solid var(--outline-variant, #c4c8bb); border-right: 1px solid var(--surface-container-high, #eee7dc); text-align: center; 
                    background: @(isToday ? "var(--secondary-container, #d5eab2)" : "var(--surface-container-low, #faf3e7)");
                    color: @(isToday ? "var(--on-secondary-container, #586a3e)" : "var(--on-surface, #1e1b14)");
                    display: flex; flex-direction: column; align-items: center; justify-content: center; transition: background 0.2s;">
            <span style="font-size: 12px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; color: @(isToday ? "var(--secondary, #526438)" : "var(--outline, #74796e)"); margin-bottom: 2px;">@dayDate.ToString("ddd")</span>
            <span style="@(isToday ? "background: var(--primary, #3d532b); color: white; width: 28px; height: 28px; line-height: 28px; border-radius: 50%; font-size: 14px; font-weight: 700; box-shadow: var(--shadow-level1);" : "font-size: 16px; font-weight: 600;")">@dayDate.Day</span>
        </div>
    }

    @* ===== All-Day Row ===== *@
    <div class="all-day-label">
        Cả ngày
    </div>

    @for (int d = 0; d < 7; d++)
    {
        var dayDate = StartOfWeek.AddDays(d);
        var allDayAppts = Appointments.Where(a => a.IsAllDay && a.StartTime.Date <= dayDate.Date && a.EndTime.Date >= dayDate.Date).ToList();

        <div class="all-day-cell">
            @foreach (var appt in allDayAppts)
            {
                @if (appt.IsGroupMeeting)
                {
                    <div class="all-day-event" @onclick="() => OnEventClick.InvokeAsync(appt.Id)"
                         style="background: linear-gradient(135deg, #7C3AED, #5B21B6); border: 1px dashed rgba(255,255,255,0.4);">
                        👥 @appt.Name
                    </div>
                }
                else
                {
                    <div class="all-day-event" @onclick="() => OnEventClick.InvokeAsync(appt.Id)"
                         style="background-color: @(appt.Color ?? "var(--primary, #3d532b)");">
                        @appt.Name
                    </div>
                }
            }
        </div>
    }

    @* ===== Time Column ===== *@
    <div class="time-column" style="border-right: 1px solid var(--outline-variant, #c4c8bb); background: var(--surface-container-low, #faf3e7);">
        @for (int i = 0; i < 24; i++)
        {
            <div class="time-slot">
                @($"{i:D2}:00")
            </div>
        }
    </div>

    @* ===== Day Columns ===== *@
    @for (int d = 0; d < 7; d++)
    {
        var dayDate = StartOfWeek.AddDays(d);
        var isToday = dayDate.Date == DateTime.Today;

        <div class="day-column" style="border-right: 1px solid var(--surface-container-high, #eee7dc); position: relative;">
            <div @onclick="() => SlotClicked(dayDate)" class="day-column-content" 
                 style="background-color: @(isToday ? "rgba(82, 100, 56, 0.03)" : "transparent");">
                @foreach (var appt in Appointments.Where(a => a.StartTime.Date == dayDate.Date && !a.IsAllDay))
                {
                    var top = appt.StartTime.Hour * 60 + appt.StartTime.Minute;
                    var height = (appt.EndTime - appt.StartTime).TotalMinutes;
                    if (height < 15) height = 15;

                    @if (appt.IsGroupMeeting)
                    {
                        <div class="event-card" @onclick:stopPropagation="true" @onclick="() => OnEventClick.InvokeAsync(appt.Id)"
                             style="position: absolute; top: @(top)px; height: @(height)px; left: 2px; right: 2px;
                                    background: linear-gradient(135deg, #7C3AED, #5B21B6);
                                    color: white; padding: 4px 6px; font-size: 11px;
                                    box-shadow: 0 3px 8px rgba(124,58,237,0.35);
                                    border: 2px dashed rgba(255,255,255,0.4);
                                    z-index: 10;">
                            <div style="display: flex; align-items: center; gap: 3px; font-weight: bold; overflow: hidden; white-space: nowrap;">
                                <span style="font-size: 10px;">👥</span>
                                <span style="overflow: hidden; text-overflow: ellipsis;">@appt.Name</span>
                            </div>
                            @if (height > 30)
                            {
                                <div style="font-size: 9px; opacity: 0.85; margin-top: 2px;">
                                    @appt.StartTime.ToString("HH:mm") · @appt.ParticipantCount người
                                    @if (appt.IsCurrentUserParticipant) { <span>✓</span> }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="event-card" @onclick:stopPropagation="true" @onclick="() => OnEventClick.InvokeAsync(appt.Id)"
                             style="position: absolute; top: @(top)px; height: @(height)px; left: 2px; right: 2px;
                                    background-color: @(appt.Color ?? "var(--primary-fixed, #d0ebb7)");
                                    color: @(appt.Color != null ? "white" : "var(--on-primary-fixed, #0d2001)");
                                    padding: 4px 6px; font-size: 11px;
                                    box-shadow: 0 2px 6px rgba(84,107,65,0.15);
                                    border-left: 4px solid @(appt.Color ?? "var(--primary, #3d532b)");
                                    z-index: 5;">
                            <div style="font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@appt.Name</div>
                            @if (height > 30)
                            {
                                <div style="font-size: 9px; opacity: 0.75; margin-top: 1px;">@appt.StartTime.ToString("HH:mm")</div>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public DateTime CurrentDate { get; set; }
    [Parameter] public List<AppointmentListResponse> Appointments { get; set; } = new();
    [Parameter] public EventCallback<DateTime> OnSlotClick { get; set; }
    [Parameter] public EventCallback<Guid> OnEventClick { get; set; }

    private DateTime StartOfWeek => CurrentDate.AddDays(-1 * ((7 + (CurrentDate.DayOfWeek - DayOfWeek.Monday)) % 7)).Date;

    private async Task SlotClicked(DateTime day)
    {
        await OnSlotClick.InvokeAsync(day.AddHours(DateTime.Now.Hour));
    }
}
