
<MudDialog>
    <DialogContent>
        <div style="text-align: center; padding: 8px 0 16px;">
            <MudIcon Icon="@Icons.Material.Filled.Groups" Style="font-size: 48px; color: #7C3AED;" />
        </div>

        <MudText Typo="Typo.h6" Align="Align.Center" Class="mb-2">
            Phát hiện cuộc họp nhóm!
        </MudText>

        <MudText Typo="Typo.body1" Align="Align.Center" Class="mb-4" Style="color: #555;">
            Tìm thấy cuộc họp nhóm khớp với lịch bạn vừa nhập:
        </MudText>

        <MudPaper Class="pa-4 mb-4" Style="background: linear-gradient(135deg, #7C3AED15, #5B21B615); border: 1px solid #7C3AED40; border-radius: 12px;">
            <div class="d-flex align-center gap-3 mb-2">
                <MudIcon Icon="@Icons.Material.Filled.MeetingRoom" Style="color: #7C3AED;" />
                <MudText Typo="Typo.h6" Style="color: #7C3AED; font-weight: 700;">@Match.MeetingName</MudText>
            </div>
            <div class="d-flex align-center gap-2">
                <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" Style="color: #7C3AED;" />
                <MudText Typo="Typo.body2" Style="color: #6D28D9;">@Match.ParticipantCount người đang tham gia</MudText>
            </div>
            @if (Match.AlreadyParticipant)
            {
                <MudAlert Severity="Severity.Info" Class="mt-3" Dense="true">
                    Bạn đã là thành viên của cuộc họp này.
                </MudAlert>
            }
        </MudPaper>

        <MudText Typo="Typo.body2" Align="Align.Center" Style="color: #888;">
            Bạn muốn tham gia cuộc họp nhóm này hay tạo lịch cá nhân riêng?
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Hủy bỏ</MudButton>
        <MudButton Color="Color.Default" Variant="Variant.Outlined" OnClick="CreateSeparate"
                   StartIcon="@Icons.Material.Filled.PersonAdd">
            Tạo lịch riêng
        </MudButton>
        @if (!Match.AlreadyParticipant)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="JoinMeeting"
                       StartIcon="@Icons.Material.Filled.GroupAdd"
                       Style="background: linear-gradient(135deg, #7C3AED, #5B21B6);">
                Tham gia họp nhóm
            </MudButton>
        }
        else
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="JoinMeeting"
                       StartIcon="@Icons.Material.Filled.CheckCircle"
                       Style="background: linear-gradient(135deg, #7C3AED, #5B21B6);">
                Xem cuộc họp
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public GroupMeetingMatchResponse Match { get; set; } = new();

    public enum JoinDialogResult { Join, CreateSeparate, Cancel }

    private void Cancel() => MudDialog.Cancel();

    private void JoinMeeting() =>
        MudDialog.Close(DialogResult.Ok(JoinDialogResult.Join));

    private void CreateSeparate() =>
        MudDialog.Close(DialogResult.Ok(JoinDialogResult.CreateSeparate));
}
